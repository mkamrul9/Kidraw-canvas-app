generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Board {
  id              String   @id @default(cuid())
  title           String   @default("Untitled Whiteboard")
  backgroundColor String   @default("#ffffff")
  
  layers          Json     @default("[]")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}